ate(p);\n    try {\n      localStorage.setItem(KEY, p);\n    } catch {}\n  }, []);\n\n  const value = useMemo<Ctx>(() => ({ pref, setPref, reduced }), [pref, setPref, reduced]);\n  return <MotionCtx.Provider value={value}>{children}</MotionCtx.Provider>;\n}\n\nconst FALLBACK: Ctx = {\n  pref: \"auto\",\n  setPref: () => {},\n  reduced: false,\n};\n\nexport function useMotionPref() {\n  const ctx = useContext(MotionCtx);\n  return ctx ?? FALLBACK;\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\vishw\\Music\\Learnify AI\\src\\hooks\\use-site-settings.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":35,"column":32,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":35,"endColumn":35,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1088,1091],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1088,1091],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useQuery } from \"@tanstack/react-query\";\nimport { supabase } from \"@/integrations/supabase/client\";\n\nexport type SiteSettings = {\n  contact_email: string;\n  careers_email: string;\n  discord_url: string;\n  discord_label: string;\n  twitter_url: string;\n  twitter_handle: string;\n  github_url: string;\n  linkedin_url: string;\n  youtube_url: string;\n};\n\nconst defaults: SiteSettings = {\n  contact_email: \"hello@learnify.ai\",\n  careers_email: \"careers@learnify.ai\",\n  discord_url: \"https://discord.gg/learnify\",\n  discord_label: \"Chat with the community in real time.\",\n  twitter_url: \"https://x.com/learnifyai\",\n  twitter_handle: